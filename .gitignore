# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# scratch / article drafts
article.txt

# typescript
*.tsbuildinfo
next-env.d.ts

# Search Console API credentials (never commit — local only, read-only)
scripts/gsc/credentials.json
gsc-credentials.json
GSC_CREDENTIALS

# PageSpeed Insights API key (never commit — local only)
scripts/ps/apikey.txt
PSI_API_KEY

# Bing Webmaster Tools API key (never commit — local only)
scripts/bing/apikey.txt
BING_API_KEY

# Gemini (LLM prose writer) API key (never commit — local only)
scripts/llm/apikey.txt
GEMINI_API_KEY

# Local SEO monitor log (generated by scheduled task)
seo-log.txt

# SEO trend history & Bing auto-submit state (local only)
scripts/seo/seo-history.json
scripts/seo/ideas.json
scripts/bing/submitted.json
