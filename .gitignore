# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# auto-post dedupe state (generated at runtime)
data/autopost-posted.json

# vercel
.vercel

# scratch / article drafts
article.txt

# typescript
*.tsbuildinfo
next-env.d.ts

# Search Console API credentials (never commit — local only, read-only)
scripts/gsc/credentials.json
gsc-credentials.json
GSC_CREDENTIALS

# PageSpeed Insights API key (never commit — local only)
scripts/ps/apikey.txt
PSI_API_KEY

# Bing Webmaster Tools API key (never commit — local only)
scripts/bing/apikey.txt
BING_API_KEY

# LLM API keys (never commit — local only)
scripts/llm/apikey.txt
scripts/llm/zen-key.txt
scripts/llm/alibaba cloude.txt
scripts/llm/*.bak
GEMINI_API_KEY
ALIBABA_API_KEY

# Local SEO monitor log (generated by scheduled task)
seo-log.txt

# SEO trend history & Bing auto-submit state (local only)
scripts/seo/seo-history.json
scripts/seo/ideas.json
scripts/bing/submitted.json

# dev server logs & temp scripts
dev-server.*
convert-tmp.mjs

# GBP helper scripts (one-off tools for local setup)
gbp-update-ids.mjs

.vercel
article-gen-log.txt
article-gen-test-run.txt

# generated article/SEO logs (local only)
gen-*-log.txt
seo-*-log.txt
seo-*-last*.txt
dev-server.log

# Pra-optimasi gambar WebP (dibuat saat build, di-commit agar online ready)
