# Chatbot CS AI — pilih satu provider (LLM_PROVIDER):
#   openai   -> OpenAI resmi / DeepSeek / OpenRouter / Grok (atur OPENAI_BASE_URL)
#   gemini   -> Google Gemini
#   anthropic-> Claude
LLM_PROVIDER=openai

# --- OpenAI-compatible (default; juga untuk DeepSeek/OpenRouter via BASE_URL) ---
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# --- Gemini (termurah & andal: ~$0.10 / 1M token) ---
# GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.0-flash

# --- Anthropic Claude ---
# ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-haiku-4-5
