# === Auto-post artikel blog ke Facebook & Instagram (Meta Graph API) ===
# Salin jadi .env.local (Next.js otomatis membacanya).
# Semua nilai di bawah diisi saat setup Meta App — lihat panduan di chat.

# URL situs (tanpa trailing slash)
SITE_URL=https://karyamediasouvenir.com

# ID Facebook Page "Suvenir Kenang Kenangan" (angka)
FB_PAGE_ID=

# Long-lived Page Access Token (tidak kedaluwarsa)
FB_PAGE_ACCESS_TOKEN=

# ID Instagram Business "agungchn369" (angka, bukan username)
IG_USER_ID=

# String acak untuk mengamankan endpoint /api/autopost
# Buat dengan:  node -e "console.log(require('crypto').randomBytes(24).toString('hex'))"
AUTOPOST_SECRET=

# Maksimal artikel baru yang dipost per jalan (default 3, untuk catch-up)
AUTOPOST_LIMIT=3

# Opsional: store state di Upstash/Vercel KV (WAJIB kalau deploy serverless
# seperti Vercel/Netlify karena filesystem read-only). Kosongkan kalau pakai
# VPS/Node dengan filesystem writable (state disimpan di data/autopost-posted.json).
# AUTOPOST_STATE_URL=
# AUTOPOST_STATE_TOKEN=
